@model List<Reservas.Entities.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";
}

<style>
    .fodun-header-tab {
        background-color: #A61C24 !important;
        color: white !important;
        font-weight: bold;
        border-radius: 4px 4px 0 0;
    }
    .fodun-btn-seleccionar {
        background-color: #A61C24 !important;
        color: white !important;
        border: none;
        font-weight: 500;
        padding: 6px 20px;
    }
    .fodun-btn-seleccionar:hover {
        background-color: #821218 !important;
        color: white !important;
    }
    .nav-tabs-fodun .nav-link.active {
        background-color: #FFFFFF !important;
        color: #A61C24 !important;
        font-weight: bold;
        border-bottom-color: transparent;
    }
    .nav-tabs-fodun .nav-link {
        color: #495057;
        background-color: #E9ECEF;
        margin-right: 2px;
    }
    .table-fodun th {
        background-color: #E2E2E2 !important;
        color: #333333;
        font-weight: 500;
        text-align: center;
    }
</style>

<div class="container mt-4">
    <h3 class="text-danger fw-normal mb-4" style="color: #A61C24 !important;">Mis Reservas</h3>

    <ul class="nav nav-tabs nav-tabs-fodun border-0 mb-0">
        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="Index">Sedes Recreativas y Apartamentos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active border-1" href="#">Mis Reservas</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Reserva" asp-action="MisReservas">Actualizar Datos</a>
        </li>
    </ul>

    <div class="border p-1 bg-white shadow-sm">
        <div class="table-responsive">
            <table class="table table-bordered align-middle table-fodun mb-0" style="border-top: 2px solid #A61C24;">
                <thead>
                    <tr>
                        <th>Lugar</th>
                        <th>Fecha Reserva</th>
                        <th>Fecha Llegada</th>
                        <th>Fecha Salida</th>
                        <th>No. Personas</th>
                        <th>No. Habitaciones</th>
                        <th>Valor Total</th>
                        <th>Comprobante de Pago</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var r in Model)
                        {
                            var habitaciones = r.TipoReserva == "Hospedaje" && r.EspacioId.HasValue ? 1 : 0;

                            <tr>
                                <td>@r.Sede?.Nombre</td>
                                <td class="text-center">@r.CreadoEn.ToString("dd-MM-yyyy")</td>
                                <td class="text-center">@r.FechaInicio.ToString("dd-MM-yyyy")</td>
                                <td class="text-center">@r.FechaFin.ToString("dd-MM-yyyy")</td>
                                <td class="text-center">@r.Personas</td>
                                <td class="text-center">@habitaciones</td>
                                <td class="text-center">@string.Format("{0:C0}", r.ValorTotal)</td>
                                <td class="text-center">
                                    @if (string.IsNullOrWhiteSpace(r.ComprobantePagoUrl))
                                    {
                                        <button type="button" class="btn btn-sm btn-danger">Enviar</button>
                                    }
                                    else
                                    {
                                        <a class="btn btn-sm btn-outline-secondary" href="@r.ComprobantePagoUrl" target="_blank">Ver</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                No tienes reservas registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>