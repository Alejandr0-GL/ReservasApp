@model Reservas.Web.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar Clave";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white text-center py-3">
                    <h4 class="mb-0">Recuperación de Clave</h4>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="NroDocumento" class="form-label fw-bold">Número de Documento</label>
                            <input asp-for="NroDocumento" class="form-control" placeholder="Ej: 10203040" />
                            <span asp-validation-for="NroDocumento" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DireccionEmail" class="form-label fw-bold">Correo Electrónico</label>
                            <input asp-for="DireccionEmail" class="form-control" placeholder="correo@ejemplo.com" />
                            <span asp-validation-for="DireccionEmail" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-secondary">Enviar enlace</button>
                            <a asp-action="Login" class="btn btn-outline-secondary">Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>