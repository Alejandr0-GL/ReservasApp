@model Reservas.Web.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Restablecer Clave";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0">Restablecer Clave</h4>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <form asp-action="ResetPassword" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Token" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="NuevaClave" class="form-label fw-bold">Nueva Clave (4 dígitos)</label>
                            <input asp-for="NuevaClave" class="form-control text-center fw-bold" maxlength="4" />
                            <span asp-validation-for="NuevaClave" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmarClave" class="form-label fw-bold">Confirmar Clave</label>
                            <input asp-for="ConfirmarClave" class="form-control text-center fw-bold" maxlength="4" />
                            <span asp-validation-for="ConfirmarClave" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Actualizar clave</button>
                            <a asp-action="Login" class="btn btn-outline-secondary">Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>